@using System.Globalization;
@model BackOfficeLibrary.OverdueViewModel
@{
    var _cultureEN = new CultureInfo("th-TH");
}

<div id="ViewOverdueFrom" class="offcanvas offcanvas-info offcanvas-end mobile-offcanvas" tabindex="-1"
    aria-labelledby="ViewOverdueFromLabel">

    <div class="offcanvas-body">

        <div class="row mb-3">
            <div class="col-7">
                <h4 id="ViewOverdueFromLabel" class="offcanvas-title">ข้อมูลการติดตามการค้างบริจาค</h4>
            </div>
            <div class="col-5 text-end">
                <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
            </div>
        </div>

        <div class="row mt-3">

            <div class="col-lg-3 col-6">
                <small class="text-muted">
                    @localize["Student_Id"]
                </small>
                <div class="fw-bold">
                    @Model.Code
                </div>
            </div>

            <div class="col-lg-3 col-6">
                <small class="text-muted">
                    @localize["FullName"]
                </small>
                <div class="fw-bold">
                    @Model.StudentName
                </div>
            </div>

            <div class="col-lg-3 col-6">
                <small class="text-muted">
                    @localize["Year"]
                </small>
                <div class="fw-bold">
                    @Model.SchoolYear
                </div>
            </div>

            <div class="col-lg-3 col-6">
                <small class="text-muted">
                    @localize["Grade_Level"]
                </small>
                <div class="fw-bold">
                    @Model.GradeLevel
                </div>
            </div>

        </div>

        <div class="row mt-3">
            <div class="col-lg-3 col-6">
                <small class="text-muted">
                    วิธีการติดตาม/วิธีการแจ้ง
                </small>
                <div class="fw-bold">
                    @Model.StatusName
                </div>
            </div>
            <div class="col-lg-3 col-6">
                <small class="text-muted">
                    วันที่แจ้ง
                </small>
                <div class="fw-bold">
                    @Model.OverDueDate
                </div>
            </div>
            <div class="col-lg-3 col-6">
                <small class="text-muted">
                    คงค้าง
                </small>
                <div class="fw-bold">
                    @Model.Balance
                </div>
            </div>
        </div>
        <div class="row mt-3">
            <div class="col-lg-6 col-12">
                <small class="text-muted">
                    @localize["Description"]
                </small>
                <div class="card">
                    <div class="card-body fw-bold">
                        @Model.Description
                    </div>
                </div>

            </div>


        </div>

    </div>

</div>
