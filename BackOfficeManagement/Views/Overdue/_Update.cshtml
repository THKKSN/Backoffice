@using System.Globalization;
@model BackOfficeLibrary.OverdueDTOModel
@{
    var _cultureEN = new CultureInfo("th-TH");
}

<div id="UpdateOverdueFrom" class="offcanvas offcanvas-info offcanvas-end mobile-offcanvas" tabindex="-1"
    aria-labelledby="UpdateOverdueFromLabel">

    <div class="offcanvas-body">

        <div class="row mb-3">
            <div class="col-7">
                <h4 id="OverdueFormLabel" class="offcanvas-title">แก้ไขข้อมูลการติดตามการค้างบริจาค</h4>
            </div>
            <div class="col-5 text-end">
                <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
            </div>

            <form id="OverdueUpdateFrom" asp-controller="Overdue" asp-action="Update" method="post"
                enctype="multipart/form-data">
                <input type="hidden" asp-for="Id">
                <input type="hidden" id="initStudentId" value="@Model.Student_Id" />
                <input type="hidden" id="initSchoolYearId" value="@Model.SchoolYear_Id" />

                <input type="hidden" id="urlGetStudentsByGrade"
       value="@Url.Action("GetStudentsByGrade", "Overdue")" />

<input type="hidden" id="urlGetSchoolYearByUUID"
       value="@Url.Action("GetSchoolYearByUUID", "Overdue")" />

<input type="hidden" id="urlGetOverdueDatatable"
       value="@Url.Action("GetOverdueDatatable", "Overdue")" />



                <div class="row mt-3">
                    <div class="col-lg-4">
                        <div class="form-group">
                            <label class="form-label">
                                @localize["Grade_Level"]
                            </label>
                            <select id="gradelevelSelected"
                            class="form-control select2"
                                    asp-for="GradeLevel_Id"
                                    asp-items="ViewBag.GrandLevelList"
                                    style="width:100%" required>
                                <option value="">@localize["Select"]</option>
                            </select>

                        </div>
                    </div>
                    <div class="col-lg-4">
                        <div class="form-group">
                            <label>@localize["Student"]</label>
                            <select id="studentSelected"
                                    class="form-control select2"
                                    asp-for="Student_Id"
                                    data-request-url-student="@Url.Action("GetStudentsByGrade", "Overdue")"
                                    required>
                                <option value="">@localize["Select"]</option>
                            </select>
                        </div>
                    </div>

                    <div class="col-lg-4">
                        <div class="form-group">
                            <label class="form-label">
                                @localize["Year"]
                            </label>
                            <select id="schoolYearSelected"
        class="form-control select2"
        asp-for="SchoolYear_Id"
        data-request-url-schoolyear="@Url.Action("GetSchoolYearByUUID", "Overdue")"
        required>
                                <option value="">@localize["Select"]</option>
                            </select>
                        </div>
                    </div>

                    <div class="col-12">
                        <table id="tblOverdue" class="table table-bordered table-hover" data-request-url="@Url.Action("GetOverdueDatatable", "Overdue")">
                            <thead class="table-light">
                                <tr>
                                    <th>@localize["Term"]</th>
                                    <th class="text-end">@localize["Donated"]</th>
                                    <th class="text-end">@localize["Outstanding"]</th>
                                </tr>
                            </thead>
                            <tbody></tbody>
                        </table>
                    </div>

                    <div class="col-lg-4">
                        <div class="form-group">
                            <label class="form-label">
                                วิธีการติดตาม
                            </label>
                            <select class="form-control select2" id="statusSelect" asp-for="Status"
                                asp-items="@(new SelectList(ViewBag.StatusList, "Value", "Text"))" style="width: 100%;" value="@Model.Status"
                                required>
                                <option value="">@localize["Select"]</option>
                            </select>
                        </div>
                    </div>

                    <div class="col-lg-4">
                        <div class="form-group">
                            <label class="form-label">
                                วันที่แจ้ง
                            </label>
                            <input type="date" class="form-control" asp-for="OverDueDate" required />
                        </div>
                    </div>

                    <div class="col-lg-12">
                        <div class="form-group">
                            <label class="form-label">
                                @localize["Description"]
                            </label>
                            <textarea class="form-control" asp-for="Description"></textarea>
                        </div>
                    </div>
                </div>
                 <div class="offcanvas-footer border-top p-3 text-end">
                    <button type="submit" class="btn btn-primary m-1">
                        @localize["Update"]
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>